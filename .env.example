# Copy to .env (or export these in your shell / CI) and fill in real values.
# The same variables live in environments/staging.postman_environment.json.

# Root URL of the API under test; referenced in every request as {{BASE_URL}}
BASE_URL=https://postman-echo.com

# API key sent in the Authorization / x-api-key header via a collection-level script
API_KEY=sk_test_51H...

# Bearer token populated at run time by a pre-request/login script; leave blank in the template
AUTH_TOKEN=

# Optional per-request timeout override passed to Newman as --timeout-request
REQUEST_TIMEOUT_MS=10000
