{
  "info": {
    "_postman_id": "b7a1e0c4-5d2f-4c8e-9a3b-2f6c1d0e8a11",
    "name": "qa.codes API — CRUD Suite",
    "description": "Full CRUD lifecycle (create → read → update → delete) against the Postman Echo public demo API, plus a data-driven folder. Requests are grouped by behaviour; every request carries pm.test assertions for status, body, headers, and response time. A collection-level pre-request script injects the auth header from API_KEY and generates a unique id; the created id is captured with pm.collectionVariables.set() and reused on read/update/delete, then deleted in a teardown request. Base URL and secrets come from the environment — nothing is hardcoded.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// --- Shared setup applied to every request in the collection ---",
          "// Inject the API key as an x-api-key header on every request. Postman Echo",
          "// echoes it straight back, so the Create request can assert it round-tripped.",
          "const apiKey = pm.environment.get('API_KEY');",
          "if (apiKey) {",
          "    pm.request.headers.upsert({ key: 'x-api-key', value: apiKey });",
          "}",
          "",
          "// Add a Bearer token only when AUTH_TOKEN is populated (e.g. by a login step).",
          "const token = pm.environment.get('AUTH_TOKEN');",
          "if (token) {",
          "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// --- Global guard applied to every response ---",
          "pm.test('No server (5xx) error', function () {",
          "    pm.expect(pm.response.code).to.be.below(500);",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1. Create",
      "item": [
        {
          "name": "Create user",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generate a unique id + suffix so repeated runs never collide.",
                  "const suffix = Date.now().toString(36) + '-' + Math.random().toString(36).slice(2, 8);",
                  "pm.collectionVariables.set('runSuffix', suffix);",
                  "pm.collectionVariables.set('userId', 'usr-' + suffix);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Create returns 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time is under 10s', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(10000);",
                  "});",
                  "",
                  "pm.test('Content-Type is JSON', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Server received the created id', function () {",
                  "    pm.expect(res.json).to.have.property('id', pm.collectionVariables.get('userId'));",
                  "});",
                  "",
                  "pm.test('Created name carries the unique suffix', function () {",
                  "    pm.expect(res.json.name).to.include(pm.collectionVariables.get('runSuffix'));",
                  "});",
                  "",
                  "pm.test('Injected x-api-key header reached the server', function () {",
                  "    pm.expect(res.headers).to.have.property('x-api-key');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{userId}}\",\n  \"name\": \"{{name}} {{runSuffix}}\",\n  \"email\": \"{{email}}\",\n  \"role\": \"{{role}}\",\n  \"year\": 2026\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/post",
              "host": ["{{BASE_URL}}"],
              "path": ["post"]
            },
            "description": "Creates a user. The id is generated in the pre-request script and captured into the `userId` collection variable for the rest of the lifecycle."
          }
        }
      ]
    },
    {
      "name": "2. Read",
      "item": [
        {
          "name": "Get user by id",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Read returns 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Query echoes the requested id', function () {",
                  "    pm.expect(res.args.userId).to.eql(pm.collectionVariables.get('userId'));",
                  "});",
                  "",
                  "pm.test('Response time is under 10s', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(10000);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/get?userId={{userId}}",
              "host": ["{{BASE_URL}}"],
              "path": ["get"],
              "query": [
                { "key": "userId", "value": "{{userId}}" }
              ]
            },
            "description": "Reads back the user created in the previous step using the captured id."
          }
        },
        {
          "name": "List users by role",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('List returns 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Both filter params round-trip', function () {",
                  "    // pm.variables resolves through the active scope so iteration data overrides the default.",
                  "    pm.expect(res.args).to.include({ role: pm.variables.get('role'), page: '1' });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/get?role={{role}}&page=1",
              "host": ["{{BASE_URL}}"],
              "path": ["get"],
              "query": [
                { "key": "role", "value": "{{role}}" },
                { "key": "page", "value": "1" }
              ]
            },
            "description": "Lists users filtered by role — validates that query parameters are passed correctly."
          }
        }
      ]
    },
    {
      "name": "3. Update",
      "item": [
        {
          "name": "Update user (PUT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Update returns 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Update targets the captured id', function () {",
                  "    pm.expect(res.json.id).to.eql(pm.collectionVariables.get('userId'));",
                  "});",
                  "",
                  "pm.test('Updated name reflects the change', function () {",
                  "    pm.expect(res.json.name).to.include('(updated)');",
                  "});",
                  "",
                  "pm.test('New status field persisted', function () {",
                  "    pm.expect(res.json.status).to.eql('updated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{userId}}\",\n  \"name\": \"{{name}} {{runSuffix}} (updated)\",\n  \"email\": \"{{email}}\",\n  \"role\": \"{{role}}\",\n  \"status\": \"updated\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/put",
              "host": ["{{BASE_URL}}"],
              "path": ["put"]
            },
            "description": "Full replacement of the user created earlier."
          }
        },
        {
          "name": "Partial update (PATCH)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Patch returns 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Patched role is applied', function () {",
                  "    pm.expect(res.json.role).to.eql('lead');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{userId}}\",\n  \"role\": \"lead\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/patch",
              "host": ["{{BASE_URL}}"],
              "path": ["patch"]
            },
            "description": "Partial update that changes a single field."
          }
        }
      ]
    },
    {
      "name": "4. Delete (teardown)",
      "item": [
        {
          "name": "Delete user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Delete returns 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Delete targeted the captured id', function () {",
                  "    pm.expect(res.args.userId).to.eql(pm.collectionVariables.get('userId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/delete?userId={{userId}}",
              "host": ["{{BASE_URL}}"],
              "path": ["delete"],
              "query": [
                { "key": "userId", "value": "{{userId}}" }
              ]
            },
            "description": "Tears down the user created at the start of this iteration."
          }
        },
        {
          "name": "Verify deletion (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Reading a deleted user returns 404', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/status/404",
              "host": ["{{BASE_URL}}"],
              "path": ["status", "404"]
            },
            "description": "Confirms that a deleted resource is no longer retrievable (simulated 404)."
          }
        }
      ]
    },
    {
      "name": "5. Data-Driven",
      "item": [
        {
          "name": "Create user from data row",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "const expectedName = pm.iterationData.get('name') || pm.collectionVariables.get('name');",
                  "const expectedRole = pm.iterationData.get('role') || pm.collectionVariables.get('role');",
                  "",
                  "pm.test('Data-driven create returns 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Name from the data row is applied', function () {",
                  "    pm.expect(res.json.name).to.eql(expectedName);",
                  "});",
                  "",
                  "pm.test('Role from the data row is applied', function () {",
                  "    pm.expect(res.json.role).to.eql(expectedRole);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{name}}\",\n  \"email\": \"{{email}}\",\n  \"role\": \"{{role}}\",\n  \"source\": \"data-file\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/post",
              "host": ["{{BASE_URL}}"],
              "path": ["post"]
            },
            "description": "Runs once per data row (`-d data/users.csv` or `data/users.json`), substituting {{name}}, {{email}}, {{role}} from each iteration."
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "userId", "value": "", "type": "string" },
    { "key": "runSuffix", "value": "", "type": "string" },
    { "key": "name", "value": "Ada Lovelace", "type": "string" },
    { "key": "email", "value": "ada@example.com", "type": "string" },
    { "key": "role", "value": "engineer", "type": "string" }
  ]
}
